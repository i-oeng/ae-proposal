        "headerParameters": {
          "parameters": [
            {
              "name": "X-Proposal-Run-Id",
              "value": "={{ $json.proposal_run_id }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ $json.proposal_request }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file",
              "outputPropertyName": "data"
            }
          }
        }
      },
