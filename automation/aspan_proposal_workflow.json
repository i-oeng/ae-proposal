      "id": "6ff83416-a36d-4578-bcf1-b1105551c603",
      "name": "Extract Bill and Client Documents",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        280,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const response = $json;\nconst extraction = response.body ?? response;\nconst bill = extraction.bill?.combined_bill;\nconst client = extraction.client;\n\nif (!bill) {\n  throw new Error('No utility bill values were extracted.');\n}\nif (!client) {\n  throw new Error('No client values were extracted.');\n}\n\nconst missing = ['client_name', 'industry', 'country'].filter((field) => !client[field]);\nif (missing.length) {\n  throw new Error(`Client extraction is missing required fields: ${missing.join(', ')}`);\n}\n\nconst headers = response.headers ?? {};\nconst runId = headers['x-proposal-run-id'] ?? headers['X-Proposal-Run-Id'] ?? '';\n\nreturn [{\n  json: {\n    proposal_request: {\n      bill,\n      client: {\n        ...client,\n        has_diesel_generators: client.has_diesel_generators ?? false\n      }\n    },\n    proposal_run_id: runId,\n    extraction_warnings: extraction.warnings ?? []\n  }\n}];"
      },
      "id": "b72ec60d-4ec6-48fe-9b57-0fd16a2c0308",
      "name": "Validate and Prepare Proposal",
      "type": "n8n-nodes-base.code",
